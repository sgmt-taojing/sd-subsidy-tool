<scroll-view class="container" scroll-y>
  <!-- 顶部结果卡 -->
  <view class="result-hero {{result.checkPassed ? 'pass' : ''}}">
    <view class="hero-city">{{result.city}}</view>
    <view class="hero-subtitle">{{result.checkPassed ? '✅ 自检通过 · 符合申报条件' : '⏳ 自检结果'}}</view>
  </view>

  <!-- 测算结果卡 -->
  <view class="card result-card">
    <view class="card-header">💰 奖补估算结果</view>

    <view class="amount-row main-amount">
      <text class="amount-label">预计可申领奖补</text>
      <view class="amount-value">
        <text class="amount-num">{{result.subsidy}}</text>
        <text class="amount-unit">万元</text>
      </view>
    </view>

    <view class="breakdown-table">
      <view class="breakdown-row">
        <text class="bd-label">项目场景费用</text>
        <text class="bd-value">{{result.sceneCost}}万元</text>
      </view>
      <view class="breakdown-row highlight">
        <text class="bd-label">本次预估奖补 <text class="percent-tag">{{subsidyPercent}}%</text></text>
        <text class="bd-value primary">≈ {{result.subsidy}}万元</text>
      </view>
      <view class="breakdown-row">
        <text class="bd-label">最高奖补上限</text>
        <text class="bd-value muted">{{result.estimateHigh}}万元</text>
      </view>
      <view class="breakdown-row final">
        <text class="bd-label">企业实际自付</text>
        <text class="bd-value danger">≈ {{result.sceneCost - result.subsidy}}万元</text>
      </view>
    </view>

    <view class="scope-note">
      估算区间：{{result.estimateLow}}万 ~ {{result.estimateHigh}}万元（最终以{{result.city}}工信局审批为准）
    </view>
  </view>

  <!-- 城市政策说明 -->
  <view class="card note-card" wx:if="{{result.cityNote}}">
    <view class="note-title">📋 {{result.city}}政策要点</view>
    <view class="note-text">{{result.cityNote}}</view>
  </view>

  <!-- 自检通过项摘要 -->
  <view class="card check-summary" wx:if="{{result.checkPassed}}">
    <view class="card-header">✅ 自检通过项目</view>
    <view class="check-summary-list">
      <view
        wx:for="{{result.checkItems}}"
        wx:key="key"
        class="check-summary-item"
      >
        <text class="cs-icon pass">✓</text>
        <text class="cs-label">{{item.label}}</text>
        <text class="cs-answer">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 个性化建议 -->
  <view class="card tips-card" wx:if="{{result.tips && result.tips.length > 0}}">
    <view class="card-header">💡 个性化建议</view>
    <view
      wx:for="{{result.tips}}"
      wx:key="index"
      class="tip-item"
    >{{item}}</view>
  </view>

  <!-- 后续步骤 -->
  <view class="card next-steps-card" wx:if="{{result.nextSteps && result.nextSteps.length > 0}}">
    <view class="card-header">🚀 下一步该怎么做</view>
    <view
      wx:for="{{result.nextSteps}}"
      wx:key="index"
      class="step-item"
    >
      <text class="step-num">{{index + 1}}</text>
      <text class="step-text">{{item}}</text>
    </view>
  </view>

  <!-- CTA按钮 -->
  <view class="cta-section">
    <button class="btn-primary btn-large" open-type="contact">联系顾问获取申报方案 →</button>
    <button class="btn-share" open-type="share">分享给同事</button>
  </view>

  <!-- 底部信息 -->
  <view class="footer-note">
    <text>数据更新日期：{{result.date}}</text>
    <text>最终奖补金额以{{result.city}}工信局审批为准</text>
    <text>如有疑问，请联系淘景数科顾问</text>
  </view>
</scroll-view>
