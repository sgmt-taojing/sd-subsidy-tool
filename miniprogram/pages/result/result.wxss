.container { padding: 24rpx; box-sizing: border-box; min-height: 100vh; background: #F2F4F7; }

/* ====== 英雄区 ====== */
.result-hero {
  background: linear-gradient(135deg, #E5575A, #C84B47);
  border-radius: 24rpx; padding: 48rpx 36rpx 36rpx;
  text-align: center; margin-bottom: 24rpx; color: #FFF;
}
.result-hero.pass {
  background: linear-gradient(135deg, #17B29F, #0E9685);
}
.hero-city { font-size: 56rpx; font-weight: 700; margin-bottom: 8rpx; }
.hero-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.9); }

/* ====== 卡片 ====== */
.card { background: #FFF; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.card-header { font-size: 30rpx; font-weight: 700; color: #1D2129; margin-bottom: 24rpx;
  border-left: 6rpx solid #17B29F; padding-left: 16rpx; }

/* ====== 奖补金额 ====== */
.amount-row { display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; }
.main-amount { background: #F0FDF9; border-radius: 12rpx; padding: 28rpx 24rpx; margin-bottom: 24rpx;
  flex-direction: column; align-items: center; text-align: center; gap: 8rpx; }
.amount-label { font-size: 28rpx; color: #4E5969; }
.amount-value { display: flex; align-items: baseline; gap: 8rpx; }
.amount-num { font-size: 88rpx; font-weight: 800; color: #17B29F; line-height: 1; }
.amount-unit { font-size: 36rpx; color: #17B29F; font-weight: 600; }

/* ====== 明细表 ====== */
.breakdown-table { border: 1px solid #E8EAED; border-radius: 12rpx; overflow: hidden; margin-bottom: 20rpx; }
.breakdown-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx; border-bottom: 1rpx solid #F0F0F0;
}
.breakdown-row:last-child { border-bottom: none; }
.breakdown-row.highlight { background: #E0F7F4; }
.breakdown-row.final { background: #FFF5F5; }
.bd-label { font-size: 28rpx; color: #4E5969; display: flex; align-items: center; gap: 10rpx; }
.bd-value { font-size: 30rpx; font-weight: 700; color: #1D2129; }
.bd-value.primary { color: #17B29F; }
.bd-value.danger { color: #E5575A; }
.bd-value.muted { color: #86909C; font-weight: 400; }
.percent-tag {
  font-size: 22rpx; background: #17B29F; color: #FFF;
  padding: 2rpx 10rpx; border-radius: 8rpx; font-weight: 600;
}
.scope-note { font-size: 24rpx; color: #86909C; text-align: center; margin-top: 8rpx; }

/* ====== 政策说明 ====== */
.note-card { background: #F0F9F7; border-left: 6rpx solid #17B29F; }
.note-title { font-size: 28rpx; font-weight: 700; color: #17B29F; margin-bottom: 12rpx; }
.note-text { font-size: 26rpx; color: #4E5969; line-height: 1.7; }

/* ====== 自检摘要 ====== */
.check-summary-list { display: flex; flex-direction: column; gap: 12rpx; }
.check-summary-item { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 16rpx;
  background: #F8FFFE; border-radius: 10rpx; }
.cs-icon { font-size: 28rpx; font-weight: 700; color: #17B29F; flex-shrink: 0; }
.cs-label { font-size: 26rpx; color: #1D2129; }

/* ====== 建议 ====== */
.tips-card { background: #FFFBE8; border-left: 6rpx solid #F5A623; }
.tips-card .card-header { border-left-color: #F5A623; }
.tip-item { font-size: 27rpx; color: #4E5969; line-height: 1.7;
  padding: 10rpx 0; border-bottom: 1rpx solid rgba(0,0,0,0.05); }
.tip-item:last-child { border-bottom: none; }

/* ====== 后续步骤 ====== */
.next-steps-card {}
.step-item { display: flex; align-items: flex-start; gap: 16rpx;
  padding: 16rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.step-item:last-child { border-bottom: none; }
.step-num {
  width: 44rpx; height: 44rpx; border-radius: 50%; background: #17B29F; color: #FFF;
  font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.step-text { font-size: 28rpx; color: #1D2129; line-height: 1.6; flex: 1; }

/* ====== CTA ====== */
.cta-section { display: flex; flex-direction: column; gap: 16rpx; margin: 8rpx 0 24rpx; }
.btn-primary {
  background: #17B29F; color: #FFF; border: none; border-radius: 14rpx;
  font-size: 34rpx; font-weight: 700; padding: 30rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(23,178,159,0.35);
}
.btn-primary.btn-large { font-size: 34rpx; }
.btn-share {
  background: #FFF; color: #17B29F; border: 2rpx solid #17B29F; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 600; padding: 22rpx 0;
}

/* ====== 底部 ====== */
.footer-note {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  padding: 24rpx 0 40rpx;
}
.footer-note text { font-size: 22rpx; color: #B0B0B0; }
