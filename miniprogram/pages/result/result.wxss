.container { padding: 16px; box-sizing: border-box; }
.result-hero {
  background: linear-gradient(135deg, #17B29F, #39D98C);
  border-radius: 16px;
  padding: 40px 24px;
  text-align: center;
  color: white;
}
.result-label { font-size: 28rpx; opacity: 0.9; }
.result-amount { margin: 16rpx 0; }
.amount-num { font-size: 100rpx; font-weight: 700; }
.amount-unit { font-size: 36rpx; margin-left: 8rpx; }
.result-range { font-size: 26rpx; opacity: 0.8; }
.card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}
.section-title { font-size: 34rpx; font-weight: 600; color: #1D2129; margin-bottom: 24rpx; }
.info-row {
  display: flex; justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #F0F0F0;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #4E5969; }
.info-value { font-size: 28rpx; color: #1D2129; font-weight: 500; }
.info-value.highlight { color: #17B29F; font-weight: 700; }
.tip-item {
  font-size: 28rpx; color: #4E5969;
  padding: 8rpx 0; line-height: 1.6;
}
.step-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1px solid #F5F5F5;
}
.step-item:last-child { border-bottom: none; }
.step-num {
  width: 40rpx; height: 40rpx;
  background: linear-gradient(135deg, #17B29F, #39D98C);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: white; font-size: 24rpx; font-weight: 600;
  flex-shrink: 0;
}
.lead-capture {
  background: #FFF;
  border: 1px solid #17B29F;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  margin: 20rpx 0;
}
.lead-title { font-size: 32rpx; font-weight: 600; color: #1D2129; margin-bottom: 12rpx; }
.lead-desc { font-size: 26rpx; color: #4E5969; margin-bottom: 20rpx; }
.qr-code { width: 200rpx; height: 200rpx; margin: 0 auto 20rpx; }
