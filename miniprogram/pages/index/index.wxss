.container {
  padding: 16px;
  box-sizing: border-box;
  min-height: 100vh;
}
.picker-box {
  padding: 22rpx 28rpx;
  border: 1px solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #B0B0B0;
  background: #FFF;
}
.picker-box.filled {
  color: #1D2129;
}
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.radio-label {
  padding: 16rpx 28rpx;
  border: 1px solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4E5969;
  transition: all 0.2s;
}
.radio-label.selected {
  border-color: #17B29F;
  background: rgba(23, 178, 159, 0.06);
  color: #17B29F;
}
.card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}
.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 16rpx;
}
.page-desc {
  font-size: 28rpx;
  color: #4E5969;
  margin-bottom: 40rpx;
  line-height: 1.6;
}
.input-group {
  margin-bottom: 32rpx;
}
.input-group > label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 12rpx;
}
.input-group input, .input-group picker {
  width: 100%;
}
