/* ====== 全局 ====== */
.container { padding: 24rpx; box-sizing: border-box; min-height: 100vh; background: #F2F4F7; }
.card { background: #FFF; border-radius: 20rpx; padding: 40rpx 36rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); }
.page-title { font-size: 44rpx; font-weight: 700; color: #1D2129; margin-bottom: 12rpx; }
.page-desc { font-size: 28rpx; color: #4E5969; line-height: 1.7; margin-bottom: 32rpx; }
.page-desc .red { color: #E5575A; font-weight: 600; }

/* ====== 步骤指示器 ====== */
.step-indicator {
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 8rpx;
}
.step-dot {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: #E8EAED; color: #999; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; flex-shrink: 0;
}
.step-dot.active { background: #17B29F; color: #FFF; }
.step-dot.done { background: #17B29F; color: #FFF; font-size: 26rpx; }
.step-line { width: 60rpx; height: 4rpx; background: #E8EAED; margin: 0 8rpx; flex-shrink: 0; }
.step-line.active { background: #17B29F; }

/* ====== 城市选择 ====== */
.city-grid {
  display: flex; flex-wrap: wrap; gap: 20rpx; padding: 0 8rpx; margin-bottom: 24rpx;
}
.city-tag {
  padding: 18rpx 36rpx; border-radius: 12rpx; font-size: 28rpx;
  background: #FFF; border: 1px solid #E8EAED; color: #4E5969;
  transition: all 0.2s; text-align: center; min-width: 130rpx;
}
.city-tag.selected { background: #17B29F; color: #FFF; border-color: #17B29F; font-weight: 600; }
.city-tag.highlight { border-color: #17B29F; color: #17B29F; }
.city-tag.highlight.selected { background: #17B29F; color: #FFF; }

/* 城市说明卡片 */
.city-intro {
  background: #E8F9F6; border-radius: 16rpx; padding: 28rpx 32rpx;
  margin-bottom: 24rpx; border-left: 6rpx solid #17B29F;
}
.city-intro-title { font-size: 30rpx; font-weight: 600; color: #17B29F; margin-bottom: 12rpx; }
.city-intro-text { font-size: 26rpx; color: #1D2129; margin-bottom: 10rpx; }
.city-intro-list { display: flex; flex-direction: column; gap: 6rpx; }
.city-intro-list text { font-size: 26rpx; color: #4E5969; }

.city-note-box {
  background: #F0F9F7; border-radius: 12rpx; padding: 20rpx 28rpx;
  margin: 24rpx 8rpx; font-size: 26rpx; color: #4E5969; line-height: 1.7;
  text-align: center;
}

/* ====== picker ====== */
.picker-box {
  padding: 22rpx 28rpx; border: 1px solid #E0E0E0; border-radius: 12rpx;
  font-size: 30rpx; color: #B0B0B0; background: #FFF; margin-bottom: 8rpx;
}
.picker-box.filled { color: #1D2129; border-color: #17B29F; }
.picker-tip { font-size: 24rpx; color: #999; margin-top: 6rpx; }

/* ====== 表单控件 ====== */
.input-group { margin-bottom: 36rpx; }
.input-group > label {
  display: block; font-size: 28rpx; font-weight: 600; color: #1D2129; margin-bottom: 16rpx;
}
.radio-group { display: flex; flex-wrap: wrap; gap: 16rpx; }
.radio-label {
  padding: 16rpx 28rpx; border: 1px solid #E0E0E0; border-radius: 12rpx;
  font-size: 26rpx; color: #4E5969; transition: all 0.2s; line-height: 1.4;
}
.radio-label.selected {
  border-color: #17B29F; background: rgba(23,178,159,0.08); color: #17B29F; font-weight: 600;
}
.scene-label { font-size: 25rpx; }

/* ====== 自检项 ====== */
.check-list { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 24rpx; }

.check-item {
  background: #FFF; border-radius: 16rpx; padding: 28rpx 28rpx;
  border: 2rpx solid #E8EAED; transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.check-item.pass { border-color: #17B29F; background: #F0FDF9; }
.check-item.fail { border-color: #E5575A; background: #FFF5F5; }

.check-item-header { margin-bottom: 8rpx; }
.check-label {
  font-size: 30rpx; font-weight: 600; color: #1D2129; line-height: 1.5;
  display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap;
}

.required-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #E5575A;
  flex-shrink: 0;
}
.optional-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #17B29F;
  flex-shrink: 0;
}

.type-tag {
  font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; font-weight: 400;
}
.tag-required { background: #FFE8E8; color: #E5575A; }
.tag-optional { background: #E0F7F4; color: #17B29F; }

.check-tip { font-size: 24rpx; color: #86909C; margin-bottom: 16rpx; line-height: 1.5; }

.check-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.check-option-btn {
  padding: 12rpx 22rpx; border: 1px solid #E0E0E0; border-radius: 10rpx;
  font-size: 26rpx; color: #4E5969; background: #FFF; transition: all 0.2s;
}
.check-option-btn.selected { border-color: #17B29F; color: #17B29F; font-weight: 600; background: rgba(23,178,159,0.06); }
.check-option-btn.opt-pass { border-color: #17B29F; color: #17B29F; background: rgba(23,178,159,0.1); font-weight: 700; }
.check-option-btn.opt-fail { border-color: #E5575A; color: #E5575A; background: #FFF0F0; font-weight: 700; }

/* ====== 自检结果 ====== */
.check-result {
  border-radius: 20rpx; padding: 40rpx 36rpx; margin-bottom: 24rpx; text-align: center;
}
.result-pass { background: linear-gradient(135deg, #E0F7F4, #D0F0E8); border: 2rpx solid #17B29F; }
.result-fail { background: #FFF5F5; border: 2rpx solid #E5575A; }
.result-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.pass-icon { color: #17B29F; }
.fail-icon { color: #E5575A; }
.result-title { font-size: 36rpx; font-weight: 700; margin-bottom: 12rpx; }
.result-pass .result-title { color: #17B29F; }
.result-fail .result-title { color: #E5575A; }
.result-desc { font-size: 28rpx; color: #4E5969; line-height: 1.7; margin-bottom: 24rpx; }

.fail-reasons { margin: 20rpx 0 24rpx; text-align: left; }
.fail-reason-item {
  background: #FFF; border-radius: 12rpx; padding: 20rpx 24rpx;
  margin-bottom: 12rpx; border-left: 4rpx solid #E5575A;
}
.fail-reason-label { font-size: 28rpx; font-weight: 600; color: #E5575A; display: block; margin-bottom: 6rpx; }
.fail-reason-tip { font-size: 24rpx; color: #86909C; line-height: 1.5; }
.fail-note { font-size: 24rpx; color: #86909C; margin-top: 16rpx; text-align: center; }

/* ====== 按钮 ====== */
.btn-primary {
  width: 100%; background: #17B29F; color: #FFF; border: none;
  border-radius: 14rpx; font-size: 32rpx; font-weight: 600;
  padding: 28rpx 0; margin-top: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(23,178,159,0.35);
}
.btn-primary[disabled] { background: #C0D8D4; box-shadow: none; }
.btn-secondary {
  width: 100%; background: #FFF; color: #17B29F; border: 2rpx solid #17B29F;
  border-radius: 14rpx; font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0; margin-top: 8rpx;
}

/* ====== 返回链接 ====== */
.back-link {
  text-align: center; font-size: 26rpx; color: #86909C;
  padding: 20rpx 0 40rpx; text-decoration: underline;
}
