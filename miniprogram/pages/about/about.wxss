.container { padding: 16px; box-sizing: border-box; }
.card { background: #FFF; border-radius: 16rpx; padding: 40rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); margin-bottom: 20rpx; }
.section-title { font-size: 34rpx; font-weight: 600; color: #1D2129; margin-bottom: 24rpx; }
.about-name { font-size: 48rpx; font-weight: 700; color: #1D2129; }
.about-slogan { font-size: 26rpx; color: #4E5969; margin-top: 12rpx; line-height: 1.5; }
.about-text { font-size: 28rpx; color: #4E5969; line-height: 1.6; margin-bottom: 24rpx; }
.about-feature { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1px solid #F5F5F5; }
.about-feature:last-child { border-bottom: none; }
.feature-icon { font-size: 48rpx; flex-shrink: 0; }
.feature-title { font-size: 30rpx; font-weight: 500; color: #1D2129; }
.feature-desc { font-size: 26rpx; color: #4E5969; margin-top: 6rpx; }
.contact-row { display: flex; gap: 8rpx; padding: 12rpx 0; font-size: 28rpx; color: #4E5969; }
